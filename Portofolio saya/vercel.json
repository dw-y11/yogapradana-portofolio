{
  "functions": {
    "api/*.php": {
      "runtime": "vercel-php@0.9.0"
    }
  },
  "rewrites": [
    {
      "source": "/send-message",
      "destination": "/api/send-message.php"
    },
    {
      "source": "/((?!api|css|js|assets).*)",
      "destination": "/api/index.php"
    },
    {
      "source": "/",
      "destination": "/api/index.php"
    }
  ]
}
